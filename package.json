  "description": "Peer-to-peer watch parties for football, with an on-device AI match companion. No servers, no accounts, no API keys.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Uthmannabeel/terrace"
  },
  "engines": {
    "node": ">=22.17"
  },
  "scripts": {
